{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G3Y5vgNQvRCtrGUQX4boBD","type":"tool_result","content":"44\tdef build_pipeline(model_type, params):\n45\t    cat_cols = [\"home_confederation\", \"away_confederation\"]\n46\t    num_cols = [c for c in FEATURE_COLS if c not in cat_cols]\n47\t    \n48\t    from sklearn.compose import ColumnTransformer\n49\t    from sklearn.preprocessing import OrdinalEncoder\n50\t\n51\t    enc = ColumnTransformer([\n52\t        (\"cat\", OrdinalEncoder(handle_unknown=\"use_encoded_value\", unknown_value=-1), cat_cols),\n53\t        (\"num\", \"passthrough\", num_cols),\n54\t    ])\n55\t    \n56\t    if model_type == \"rf\":\n57\t        clf = RandomForestClassifier(random_state=SEED, **params)\n58\t    elif model_type == \"et\":\n59\t        clf = ExtraTreesClassifier(random_state=SEED, **params)\n60\t    elif model_type == \"hgb\":\n61\t        clf = HistGradientBoostingClassifier(random_state=SEED, **params)\n62\t    elif model_type == \"elo_logistic\":\n63\t        clf = LogisticRegression(max_iter=1000, random_state=SEED, **params)\n64\t    else:\n65\t        raise ValueError(f\"Unknown model_type: {model_type}\")\n66\t    \n67\t    return Pipeline([(\"enc\", enc), (\"clf\", clf)])\n68\t\n69\tdef run_cv(model_type, params, feature_cols=None):\n70\t    df = build_match_features()\n71\t    fc = feature_cols or FEATURE_COLS\n72\t    X = df[fc].fillna(0)\n73\t    y = df[\"label\"]\n74\t    \n75\t    pipe = build_pipeline(model_type, params)\n76\t    cv = RepeatedStratifiedKFold(n_splits=N_SPLITS, n_repeats=N_REPEATS, random_state=SEED)\n77\t    \n78\t    def neg_logloss(est, X, y):\n79\t        proba = est.predict_proba(X)\n80\t        classes = list(est.classes_)\n81\t        return -log_loss(y, proba, labels=classes)\n82\t    \n83\t    scores = cross_validate(pipe, X, y,\n84\t                            cv=cv,\n85\t                            scoring={\"neg_logloss\": neg_logloss, \"accuracy\": \"accuracy\"},\n86\t                            return_train_score=False)\n87\t    \n88\t    ll_mean = -scores[\"test_neg_logloss\"].mean()\n89\t    ll_std = scores[\"test_neg_logloss\"].std()\n90\t    acc_mean = scores[\"test_accuracy\"].mean()\n91\t    acc_std = scores[\"test_accuracy\"].std()\n92\t    \n93\t    return ll_mean, ll_std, acc_mean, acc_std, X, y, pipe\n94\t\n95\tdef get_feature_importance(model_type, params, fc):\n96\t    df = build_match_features()\n97\t    X = df[fc].fillna(0)\n98\t    y = df[\"label\"]\n99\t    from sklearn.compose import ColumnTransformer\n100\t    cat_cols = [\"home_confederation\", \"away_confederation\"]\n101\t    num_cols = [c for c in fc if c not in cat_cols]\n102\t    from sklearn.preprocessing import OrdinalEncoder\n103\t    enc = ColumnTransformer([\n104\t        (\"cat\", OrdinalEncoder(handle_unknown=\"use_encoded_value\", unknown_value=-1), cat_cols),\n105\t        (\"num\", \"passthrough\", num_cols),\n106\t    ])\n107\t    from sklearn.pipeline import Pipeline\n108\t    if model_type == \"rf\":\n109\t        clf = RandomForestClassifier(random_state=SEED, **params)\n110\t    elif model_type == \"et\":\n111\t        clf = ExtraTreesClassifier(random_state=SEED, **params)\n112\t    elif model_type == \"hgb\":\n113\t        clf = HistGradientBoostingClassifier(random_state=SEED, **params)\n114\t    else:\n115\t        return {}\n116\t    \n117\t    pipe = Pipeline([(\"enc\", enc), (\"clf\", clf)])\n118\t    Xt = enc.fit_transform(X)\n119\t    col_names = list(cat_cols) + list(num_cols)\n120\t    clf.fit(Xt, y)\n121\t    if hasattr(clf, \"feature_importances_\"):\n122\t        imp = dict(sorted(zip(col_names, clf.feature_importances_.tolist()), key=lambda x: -x[1]))\n123\t        return imp\n124\t    return {}\n125\t\n126\tdef main():\n127\t    exp_id = sys.argv[1]\n128\t    model_type = sys.argv[2]\n129\t    params = json.loads(sys.argv[3]) if len(sys.argv) > 3 else {}\n130\t    feature_cols = json.loads(sys.argv[4]) if len(sys.argv)